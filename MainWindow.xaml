<Window x:Class="Ollama_panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ollama 控制面板" Height="520" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 状态区域 -->
        <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse x:Name="StatusDot" Fill="Red" Style="{StaticResource StatusDot}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="已停止" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="VersionText" Text="" Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnStart" Grid.Column="0" Content="启动 Ollama" Height="40" Margin="0,0,6,0" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Grid.Column="1" Content="停止 Ollama" Height="40" Margin="6,0,0,0" Click="BtnStop_Click" IsEnabled="False"/>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="2" Header="日志输出" Margin="0,0,0,12">
            <TextBox x:Name="LogBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                     VerticalAlignment="Stretch"/>
        </GroupBox>

        <!-- 设置区域 -->
        <GroupBox Grid.Row="3" Header="设置">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Ollama 路径：" VerticalAlignment="Center" Width="80"/>
                    <TextBox x:Name="OllamaPathBox" Text="C:\Users\Rainbow\AppData\Local\Programs\Ollama\ollama.exe" Width="230" VerticalAlignment="Center"/>
                    <Button Content="浏览..." Width="50" Height="24" Margin="6,0,0,0" Click="BtnBrowse_Click"/>
                </StackPanel>
                <CheckBox x:Name="AutoStartCheckBox" Content="开机自启" Margin="0,0,0,4"/>
                <CheckBox x:Name="ShowLogCheckBox" Content="显示日志" IsChecked="True"/>
                <CheckBox x:Name="MinimizeToTrayCheckBox" Content="最小化到托盘" IsChecked="True"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
